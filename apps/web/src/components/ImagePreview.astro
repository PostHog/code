---
import DottedContainer from "./DottedContainer.astro";

interface Props {
  src: string;
  alt?: string;
}

const { src, alt = "" } = Astro.props;
---

<DottedContainer class="image-preview-container">
  <img src={src} alt={alt} class="image-preview-img invertible" />
</DottedContainer>

<style>
  .image-preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
