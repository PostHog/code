---
interface Props {
  visible?: boolean;
  labels?: boolean;
}

const { visible = true, labels = false } = Astro.props;
---
{visible && (
  <div class="grid-overlay" aria-hidden="true">
    <div class="grid-overlay-inner">
      <div class="grid-rail rail-1">{labels && <span>1</span>}</div>
      <div class="grid-rail rail-2">{labels && <span>2</span>}</div>
      <div class="grid-rail rail-3">{labels && <span>3</span>}</div>
      <div class="grid-rail rail-4">{labels && <span>4</span>}</div>
      <div class="grid-rail rail-5">{labels && <span>5</span>}</div>
    </div>
  </div>
)}
